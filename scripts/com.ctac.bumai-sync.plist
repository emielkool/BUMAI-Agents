<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.ctac.bumai-sync</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>cd REPO_PATH_PLACEHOLDER &amp;&amp; git fetch origin main &amp;&amp; git checkout main &amp;&amp; git reset --hard origin/main &gt;&gt; /tmp/bumai-sync.log 2&gt;&amp;1 &amp;&amp; rsync -av 'REPO_PATH_PLACEHOLDER/briefings/' 'ONEDRIVE_PATH_PLACEHOLDER/briefings/' &gt;&gt; /tmp/bumai-sync.log 2&gt;&amp;1 &amp;&amp; echo "Sync briefings/ voltooid" &gt;&gt; /tmp/bumai-sync.log 2&gt;&amp;1</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key><integer>7</integer>
        <key>Minute</key><integer>30</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/tmp/bumai-sync.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/bumai-sync-error.log</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
